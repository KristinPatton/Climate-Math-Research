    {
      "cell_type": "code",
      "source": [
        "# SVD analysis\n",
        "Zanom = Elev - np.mean(Elev, axis=1, keepdims=True)\n",
        "# SVD\n",
        "U, S, VT = np.linalg.svd(Zanom, full_matrices=False)\n",
        "\n",
        "print(\"Singular Values:\", S)\n",
        "print(\"\\nEOF Modes (U):\")\n",
        "print(U)\n",
        "\n",
        "for i in range(4):\n",
        "  plt.subplot(2,2,i+1)\n",
        "  plt.plot(mon, VT[i,:]*S[i], marker='o')\n",
        "  plt.title(f\"PC {i+1}\")\n",
        "  plt.xlabel(\"Month\")\n",
        "  plt.ylabel(\"Magnitude\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Plot singular values\n",
        "plt.figure()\n",
