    {
      "cell_type": "markdown",
      "source": [
        "The Hypsometric Equation:\n",
        "$$ z_2 = z_1 + \\frac{2 R T_1 T_2}{g(T_2 + T_1)} \\ln\\left(\\frac{p_1}{p_2}\\right) $$"
      ],
      "metadata": {
        "id": "W_uAVwr05fES"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# hypsometric equation\n",
        "R = 287.055    # gas constant (J/kg*K)\n",
        "g = 9.81       # gravity (m/s^2)\n",
        "Z_a = np.column_stack((z_a, z_a, z_a, z_a))\n",
        "Z = Z_a.copy()\n",
        "\n",
        "def height(z1, T1, T2, p1, p2):\n",
        "    return z1 + (2*R*T1*T2)/(g*(T1+T2))*np.log(p1/p2)\n",
        "\n",
        "# The mountains are in order from shortest to tallest.\n",
        "# We use Sassafras as our base mountain and calculate the heights\n",
        "# for each mountain based on the mountain before it.\n",
        "\n",
        "for i in range(4):\n",
        "    for j in range(4):\n",
        "        Z[i+1,j] = height(Z[i,j], T[i,j], T[i+1,j], P[i,j], P[i+1,j])\n",
        "\n",
        "print(Z/0.3048) # Calculated elevation in ft\n",
        "RelErr = np.abs(Z_a - Z)/Z_a # relative error\n",
        "print(RelErr)\n"
        "print(f"Average percent relative error:{np.mean(RelErr[1:,:]*100)}")\n"
      ],
      "metadata": {
        "id": "tdUkVmtg-5EX",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "7d3327d5-9955-4060-e41e-841b7158253e"
      },
      "execution_count": 9,
      "outputs": [
